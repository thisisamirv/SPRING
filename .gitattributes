# Default behavior: handle as text and normalize (LF in repo, OS-default in working copy)
* text=auto

# Source code and config always normalized
*.cpp text
*.h text
*.txt text
*.cmake text
CMakeLists.txt text
.gitignore text
.gitattributes text

# Unix Shell scripts: always LF in repo and working copy
*.sh text eol=lf

# Windows-specific scripts: always CRLF in working copy
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.gz binary
*.tar.xz binary
*.pdf binary
*.exe binary
*.dll binary
*.so binary
*.a binary
*.lib binary
